# ─── Mode 1: Manual (provide pre-existing agent credentials) ─────────────
# Agent credentials from the 1Claw dashboard or CLI.
ONECLAW_AGENT_ID=your-agent-uuid
ONECLAW_AGENT_API_KEY=ocv_your_agent_key

# ─── Mode 2: Bootstrap (auto-provision everything from a human API key) ──
# Set this INSTEAD of ONECLAW_AGENT_ID + ONECLAW_AGENT_API_KEY.
# The sidecar will create a vault, agent (with Shroud enabled), and policy
# on first start. Credentials are cached in a state file for restarts.
# ONECLAW_MASTER_API_KEY=1ck_your_human_key

# Vault name for bootstrap (default: shroud-sidecar)
# ONECLAW_VAULT_NAME=shroud-sidecar

# Agent name for bootstrap (default: shroud-sidecar-agent)
# ONECLAW_AGENT_NAME=shroud-sidecar-agent

# Secret path policy pattern (default: ** = all secrets)
# ONECLAW_POLICY_PATH=**

# Where to cache bootstrap state (default: ~/.1claw/shroud-sidecar-state.json)
# ONECLAW_STATE_FILE=/path/to/state.json

# API base URL for bootstrap (default: https://api.1claw.xyz)
# ONECLAW_BASE_URL=https://api.1claw.xyz

# Set to "true" to also delete the vault on teardown (default: agent only)
# ONECLAW_AUTO_DESTROY_VAULT=false

# ─── Common (both modes) ────────────────────────────────────────────────
# Shroud endpoint (default: https://shroud.1claw.xyz)
# ONECLAW_SHROUD_URL=https://shroud.1claw.xyz

# Default LLM provider if the caller doesn't set X-Shroud-Provider.
# Values: openai, anthropic, google, mistral, cohere, openrouter
# ONECLAW_DEFAULT_PROVIDER=openai

# Default model if the caller doesn't set X-Shroud-Model or include "model" in the body.
# ONECLAW_DEFAULT_MODEL=gpt-4o-mini

# Vault ID — passed in audit logs; auto-populated in bootstrap mode.
# ONECLAW_VAULT_ID=

# Workspace or environment identifier — included in audit log for tracing.
# CODER_WORKSPACE_ID=

# Address and port to listen on (default: :8080)
# LISTEN_ADDR=:8080
